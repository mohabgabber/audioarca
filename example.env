# Copy this file to .env and replace the placeholder values.

# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=false
APP_DOMAIN=example.com
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=https://example.com
TIME_ZONE=UTC

# Database
DATABASE_NAME=forensics
DATABASE_USER=forensics
DATABASE_PASSWORD=replace-me
DATABASE_HOST=postgres
DATABASE_PORT=5432
POSTGRES_DB=forensics
POSTGRES_USER=forensics
POSTGRES_PASSWORD=replace-me

# Queue and cache
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_BEAT_SCHEDULE_FILENAME=.runtime/celerybeat-schedule

# OpenAI report generation
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.4

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-me
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=forensics@example.com

# Local/private storage
MEDIA_ROOT=media
STATIC_ROOT=staticroot
PRIVATE_MEDIA_ROOT=private_media
FORENSICS_MODEL_ROOT=model_assets
FORENSICS_FASTTEXT_MODEL_PATH=model_assets/fasttext/lid.176.bin

# Local model/runtime options
FORENSICS_WHISPER_MODEL_SIZE=small
FORENSICS_SPEECHBRAIN_SOURCE=speechbrain/spkrec-ecapa-voxceleb

# Optional S3 storage mode
USE_S3_STORAGE=false
S3_BUCKET_NAME=replace-me
S3_REGION_NAME=replace-me
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
CLOUDFRONT_DOMAIN=
